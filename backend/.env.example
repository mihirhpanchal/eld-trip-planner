DEBUG=False
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=.onrender.com,.railway.app,localhost,127.0.0.1

# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app

# Optional: swap to a self-hosted OSRM or keep the public demo
OSRM_BASE_URL=https://router.project-osrm.org
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=eld-trip-planner/1.0 (contact: your-email@example.com)

# Optional: Postgres (Render/Railway). Leave blank to use sqlite.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
